# ===========================================
# Cocos Security Portal - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ----- Database -----
DATABASE_URL="postgresql://postgres:password@localhost:5432/cocos_security"

# ----- Auth (NextAuth v5) -----
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here-generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# ----- Redis (BullMQ) -----
REDIS_URL="redis://localhost:6379"

# ----- External APIs (optional - for real integrations) -----
# VirusTotal - https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=""

# URLScan.io - https://urlscan.io/user/profile/
URLSCAN_API_KEY=""

# HaveIBeenPwned - https://haveibeenpwned.com/API/Key
HIBP_API_KEY=""

# Twitter/X API v2 - https://developer.x.com/en/portal/dashboard
# Free tier is enough: create an app, grab the Bearer Token
TWITTER_BEARER_TOKEN=""

# Slack Webhooks - for alert notifications
SLACK_WEBHOOK_URL=""
SLACK_BOT_TOKEN=""

# ----- App Config -----
NEXT_PUBLIC_APP_NAME="Cocos Security Portal"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
